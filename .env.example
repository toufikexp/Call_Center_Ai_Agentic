# Copy this file to `.env` at the project root and fill in real values.
# Never commit `.env` — it is git-ignored.
#
# The loader is `load_env_file()` in src/config/config.py. Variables already
# set in the shell environment take precedence over values in `.env`.

# ---------------------------------------------------------------------------
# Gemini API (used by RefinementService for transcript refinement)
# ---------------------------------------------------------------------------
# Required to enable refinement. If unset, refinement is skipped, the
# refinement_score stays at 0.0, and the pipeline routes to MANUAL_REVIEW.
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Local vLLM server (used by ClassificationService and SentimentService)
# ---------------------------------------------------------------------------
# OpenAI-compatible endpoint exposed by your vLLM deployment.
VLLM_BASE_URL=http://localhost:8080/v1

# Model name as registered with the vLLM server (must match exactly).
VLLM_MODEL_NAME=Qwen/Qwen3-4B

# Most vLLM deployments don't require an API key; leave as `none` if so.
VLLM_API_KEY=none

# Sampling temperature for classification + sentiment. Keep low (0.0–0.2)
# for deterministic, structured JSON output.
VLLM_TEMPERATURE=0.1

# ---------------------------------------------------------------------------
# Optional: override the classification taxonomy file
# ---------------------------------------------------------------------------
# Defaults to src/config/classification_schema.json when unset.
# CLASSIFICATION_SCHEMA_PATH=/abs/path/to/custom_schema.json
