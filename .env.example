# Copy this file to `.env` at the project root and fill in real values.
# Never commit `.env` — it is git-ignored.
#
# The loader is `load_env_file()` in src/config/config.py. Variables already
# set in the shell environment take precedence over values in `.env`.

# ---------------------------------------------------------------------------
# Gemini API (used by RefinementService for transcript refinement)
# ---------------------------------------------------------------------------
# Required to enable refinement. If unset, refinement is skipped, the
# refinement_score stays at 0.0, and the pipeline routes to MANUAL_REVIEW.
GEMINI_API_KEY=

# Gemini model to use for refinement. Defaults to `gemini-2.0-flash` (stable).
# Other usable values: `gemini-2.5-flash`, `gemini-2.5-pro`. Avoid the
# `*-exp` preview names — they get removed without notice.
# GEMINI_MODEL_NAME=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Local vLLM server (used by ClassificationService and SentimentService)
# ---------------------------------------------------------------------------
# OpenAI-compatible endpoint exposed by your vLLM deployment.
VLLM_BASE_URL=http://localhost:8080/v1

# Model name as registered with the vLLM server (must match exactly).
VLLM_MODEL_NAME=Qwen/Qwen3-4B

# Most vLLM deployments don't require an API key; leave as `none` if so.
VLLM_API_KEY=none

# Sampling temperature for classification + sentiment. Keep low (0.0–0.2)
# for deterministic, structured JSON output.
VLLM_TEMPERATURE=0.1

# ---------------------------------------------------------------------------
# Whisper / LoRA configuration
# ---------------------------------------------------------------------------
# Base Whisper model. Adapters target this base; tokenizer + feature extractor
# are loaded from here regardless of whether an adapter is applied.
WHISPER_BASE_MODEL_ID=openai/whisper-large-v3

# Path to a fine-tuned LoRA adapter directory (containing adapter_config.json
# and adapter_model.safetensors). When set, the service loads the base model
# above and merges the adapter on top in memory. When unset, WHISPER_MODEL_PATH
# is treated as a full merged checkpoint.
# WHISPER_ADAPTER_PATH=/opt/models/whisper-large-v3-lora-algerian_v7

# Path to a full Whisper checkpoint. Only used when WHISPER_ADAPTER_PATH is unset.
# Defaults to a fine-tuned checkpoint inside the project; override per machine.
# WHISPER_MODEL_PATH=/opt/models/whisper-large-v3-darija

# Per-segment inference batch size on GPU. 4–8 is a good range for 8–16 GB VRAM.
WHISPER_BATCH_SIZE=4

# Set to "1" to load the base model in 8-bit via bitsandbytes (slower than fp16
# on most GPUs; useful only when VRAM is tight). Off by default.
WHISPER_USE_8BIT=0

# ---------------------------------------------------------------------------
# Audio preprocessing (channel split + Silero VAD)
# ---------------------------------------------------------------------------
# Master switch. Disable to fall back to legacy whole-file transcription
# (not recommended; the model was trained on VAD-cut segments).
PREPROCESSING_ENABLE=1

# Silero VAD parameters.
VAD_THRESHOLD=0.5
VAD_MIN_SEGMENT_SECONDS=1.0
VAD_MAX_SEGMENT_SECONDS=30.0
VAD_PADDING_MS=250

# Channel routing for stereo recordings. Defaults match Ooredoo call center
# format (agent on left, client on right).
PREPROCESSING_AGENT_CHANNEL=0
PREPROCESSING_CLIENT_CHANNEL=1

# Set to "1" to dump per-segment WAV files under data/segments/<basename>/
# for debugging the VAD output.
PREPROCESSING_SAVE_SEGMENTS=0

# Optional local cache for the Silero VAD weights (air-gapped deployments).
# After one warm-up run, this directory contains everything needed.
# SILERO_CACHE_DIR=/opt/models/silero_vad

# ---------------------------------------------------------------------------
# Persistence (PostgreSQL) — optional
# ---------------------------------------------------------------------------
# When STORAGE_ENABLE=1, every pipeline run is recorded in PostgreSQL
# alongside the per-call JSON written to data/results/. JSON remains the
# source of truth; the DB enables analytics, idempotency (skip files
# already processed COMPLETE), batch lifecycle tracking, and dashboards.
#
# Required when enabled: psycopg v3 (`pip install 'psycopg[binary]>=3.1'`)
# and an accessible PostgreSQL server with a database created via
# `CREATE DATABASE call_center;`. The schema (calls, call_results,
# batch_runs) is created on first run.
#
# STORAGE_ENABLE=1
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/call_center

# ---------------------------------------------------------------------------
# Optional: override the classification taxonomy file
# ---------------------------------------------------------------------------
# Defaults to src/config/classification_schema.json when unset.
# CLASSIFICATION_SCHEMA_PATH=/abs/path/to/custom_schema.json
