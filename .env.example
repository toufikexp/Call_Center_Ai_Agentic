# ============================================================================
# Call Center AI Agentic Pipeline — .env.example
# Copy to `.env` (git-ignored) and edit. Source of truth for BOTH dev (WSL)
# and prod (RHEL VM) — same compose.yaml + Makefile in either, only values
# below change.
#
# Conventions:
#   - Variables consumed by docker compose (IMAGE_*, *_DIR, POSTGRES_*) drive
#     the runtime topology.
#   - Variables consumed by the pipeline itself (WHISPER_*, VLLM_*, ...) are
#     passed through to the container via `env_file`.
#   - `.env` values are also read by `python main.py` when running outside
#     Docker — `_bootstrap_env()` in main.py loads them before transformers
#     imports so HF_HUB_OFFLINE takes effect.
# ============================================================================

# ----------------------------------------------------------------------------
# Images (CPU/GPU profiles auto-pick one of these)
# ----------------------------------------------------------------------------
# CPU vs GPU is selected with a Compose PROFILE, NOT by editing files:
#   docker compose --profile cpu up -d        # or: make serve
#   docker compose --profile gpu up -d        # or: make serve TORCH=gpu
# Build the images with `make build` and `make build TORCH=gpu`.
IMAGE_CPU=cc-pipeline:cpu
IMAGE_GPU=cc-pipeline:gpu

# Run the pipeline container as a specific host uid/gid so files it writes to
# bind mounts are owned by your account, not the image's baked uid 1000.
# Dev: leave unset (defaults to 1000). Prod: set to the service account, e.g.
#   APP_UID=$(id -u dsapp)
#   APP_GID=$(id -g dsapp)
# APP_UID=1000
# APP_GID=1000

# ----------------------------------------------------------------------------
# Host paths bind-mounted into the container
# ----------------------------------------------------------------------------
# Dev (WSL): relative paths are resolved against the repo root.
# Prod (RHEL): use absolute paths owned by uid 1000 (the appuser inside the
#   container). Compose maps these to /app/data, /adapters, /hf, /models.
# One model folder on the host: ./models. It holds BOTH model families,
# each consumed by a different container:
#   models/whisper_trained_LoRa_adaptator/  → /adapters (app container)
#   models/Qwen3-4B/                        → /models   (vLLM container)
DATA_DIR=./data
ADAPTERS_DIR=./models
MODELS_DIR=./models
HF_CACHE_DIR=${HOME}/.cache/huggingface

# ----------------------------------------------------------------------------
# Postgres (compose builds DATABASE_URL from these)
# ----------------------------------------------------------------------------
# Required: POSTGRES_PASSWORD (compose refuses to start without it).
POSTGRES_USER=cc_pipeline
POSTGRES_PASSWORD=change_me                                # ← CHECK: set a real password
POSTGRES_DB=call_center

# ----------------------------------------------------------------------------
# Offline cache mode
# ----------------------------------------------------------------------------
# Dev: 0 (allow HF fetches when caches are incomplete).
# Prod: 1 (cache must be complete; fail loudly if anything is missing).
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# Inside the container, HF_HOME points at the mounted cache.
HF_HOME=/hf

# ----------------------------------------------------------------------------
# Whisper + LoRA (paths INSIDE the container)
# ----------------------------------------------------------------------------
WHISPER_BASE_MODEL_ID=openai/whisper-large-v3
WHISPER_ADAPTER_PATH=/adapters/whisper_trained_LoRa_adaptator

# Per-call segment batch size. CPU: 2. GPU: 4–8 depending on VRAM.
WHISPER_BATCH_SIZE=2

# 8-bit base model load via bitsandbytes (CUDA only). Off by default.
WHISPER_USE_8BIT=0

# Alternative to WHISPER_ADAPTER_PATH: a full merged checkpoint directory.
# Use one OR the other. WHISPER_ADAPTER_PATH wins when both are set.
# WHISPER_MODEL_PATH=/adapters/whisper-large-v3-merged

# ----------------------------------------------------------------------------
# Preprocessing (channel split + Silero VAD)
# ----------------------------------------------------------------------------
PREPROCESSING_ENABLE=1
VAD_THRESHOLD=0.5
VAD_MIN_SEGMENT_SECONDS=1.0
VAD_MAX_SEGMENT_SECONDS=30.0
VAD_PADDING_MS=250
PREPROCESSING_AGENT_CHANNEL=0
PREPROCESSING_CLIENT_CHANNEL=1
# 1 = dump per-segment WAVs under data/segments/<basename>/. Off in prod.
PREPROCESSING_SAVE_SEGMENTS=0                              # ← CHECK: 0 in prod
# SILERO_CACHE_DIR=/hf/silero_vad   # optional; rarely needed

# ----------------------------------------------------------------------------
# Batch I/O (container paths under the /app/data mount)
# ----------------------------------------------------------------------------
INPUT_DIR=/app/data/audio_files
ARCHIVE_DIR=/app/data/audio_files_archive

# ----------------------------------------------------------------------------
# Refinement (Gemini)
# ----------------------------------------------------------------------------
# Leave empty to skip refinement (refinement_score = 0 → MANUAL_REVIEW).
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_API_KEY=                                            # ← paste your key here (never in chat)

# ============================================================================
# Qwen / vLLM — TWO concerns, kept distinct
# ============================================================================

# (1) How the PIPELINE reaches vLLM (just a URL — same value whether vLLM
#     runs by hand, in compose.vllm.yaml GPU, or CPU). host.docker.internal
#     resolves to the WSL/host machine where vLLM listens on 8080.
VLLM_BASE_URL=http://host.docker.internal:8080/v1
VLLM_MODEL_NAME=Qwen/Qwen3-4B
VLLM_API_KEY=none
VLLM_TEMPERATURE=0.1

# (2) How vLLM ITSELF runs (only used when you `make vllm-gpu` / `vllm-cpu`).
#     Leave at defaults if you keep running vLLM by hand outside Docker.
VLLM_HOST_PORT=8080
VLLM_MAX_MODEL_LEN=8192

# GPU vLLM (dev). Pin a concrete tag in prod.
VLLM_GPU_IMAGE=vllm/vllm-openai:latest
VLLM_GPU_MEM_UTIL=0.6

# CPU vLLM (prod). Build locally first:
#   git clone https://github.com/vllm-project/vllm.git
#   cd vllm && docker build -f docker/Dockerfile.cpu -t vllm-cpu:local .
VLLM_CPU_IMAGE=vllm-cpu:local
VLLM_CPU_KVCACHE_SPACE=8
VLLM_CPU_OMP_THREADS=8

# Model source for vLLM:
#   - online / first run:  VLLM_MODEL=Qwen/Qwen3-4B  (HF repo id)
#   - offline / prod:      VLLM_MODEL=/models/Qwen3-4B  (local path INSIDE container)
# With HF_HUB_OFFLINE=1, use the local path AFTER downloading once:
#   huggingface-cli download Qwen/Qwen3-4B --local-dir ${MODELS_DIR}/Qwen3-4B
VLLM_MODEL=Qwen/Qwen3-4B                                   # ← CHECK: /models/Qwen3-4B once downloaded

# ----------------------------------------------------------------------------
# HTTP server (`make serve` — long-running alternative to one-shot batches)
# ----------------------------------------------------------------------------
# Job-worker threads inside the single server process. CPU: 1.
# GPU: 1-2 (raise carefully — each in-flight job competes for the same model).
SERVER_WORKERS=1
# Host port the server is exposed on (container always listens on 8000).
SERVER_HOST_PORT=8000

# ----------------------------------------------------------------------------
# Classification taxonomy override (optional)
# ----------------------------------------------------------------------------
# Defaults to src/config/classification_schema.json when unset.
# CLASSIFICATION_SCHEMA_PATH=/abs/path/to/custom_schema.json
