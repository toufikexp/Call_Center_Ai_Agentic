# Copy to `.env` and set the values that matter for your environment.
# `.env` is git-ignored; never commit it.
#
# This single file is the source of truth for BOTH dev (WSL) and prod
# (RHEL VM). The same compose.yaml and Makefile work in either by reading
# the values below.
#
# Conventions:
#   - Variables consumed by docker compose (IMAGE, *_DIR, POSTGRES_*) drive
#     the runtime topology.
#   - Variables consumed by the pipeline itself (WHISPER_*, VLLM_*, ...)
#     are passed through to the container via `env_file`.
#   - `.env` values are also read by `python main.py` when running outside
#     Docker — `_bootstrap_env()` in main.py loads them before transformers
#     imports so HF_HUB_OFFLINE takes effect.

# ===========================================================================
# Image selection
# ===========================================================================
# Default to CPU image. On a GPU dev box, rebuild with `make build TORCH=gpu`
# and set IMAGE=cc-pipeline:gpu here (or pass IMAGE=... on the command line).
IMAGE=cc-pipeline:cpu

# ===========================================================================
# Host paths bind-mounted into the container
# ===========================================================================
# Dev (WSL): relative paths work — they're resolved against the repo root.
# Prod (RHEL): use absolute paths owned by uid 1000 (the appuser inside the
#   container). The compose file maps these to /app/data, /adapters, /hf.
DATA_DIR=./data
ADAPTERS_DIR=./models
HF_CACHE_DIR=${HOME}/.cache/huggingface

# ===========================================================================
# Offline policy
# ===========================================================================
# Dev: 0 (allow HF fetches). Prod: 1 (cache must be complete; fail loudly
# if anything is missing).
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# Inside the container, HF_HOME points at the mounted cache.
HF_HOME=/hf

# ===========================================================================
# Whisper + LoRA (container paths)
# ===========================================================================
WHISPER_BASE_MODEL_ID=openai/whisper-large-v3

# Path inside the container — `${ADAPTERS_DIR}` is mounted at /adapters.
# Edit the folder name on the right to match your adapter directory.
WHISPER_ADAPTER_PATH=/adapters/whisper_trained_LoRa_adaptator

# Per-call segment batch size. CPU: 2. GPU: 4–8 depending on VRAM.
WHISPER_BATCH_SIZE=2

# 8-bit base model load via bitsandbytes (CUDA only). Off by default.
WHISPER_USE_8BIT=0

# Alternative to WHISPER_ADAPTER_PATH: a full merged checkpoint directory.
# Use one OR the other, not both. WHISPER_ADAPTER_PATH wins when set.
# WHISPER_MODEL_PATH=/adapters/whisper-large-v3-merged

# ===========================================================================
# Preprocessing (channel split + Silero VAD)
# ===========================================================================
PREPROCESSING_ENABLE=1
VAD_THRESHOLD=0.5
VAD_MIN_SEGMENT_SECONDS=1.0
VAD_MAX_SEGMENT_SECONDS=30.0
VAD_PADDING_MS=250
PREPROCESSING_AGENT_CHANNEL=0
PREPROCESSING_CLIENT_CHANNEL=1
# 1 = dump per-segment WAVs under data/segments/<basename>/. Off in prod.
PREPROCESSING_SAVE_SEGMENTS=0
# SILERO_CACHE_DIR=/hf/silero_vad   # optional; rarely needed

# ===========================================================================
# Batch I/O (container paths under the /app/data mount)
# ===========================================================================
INPUT_DIR=/app/data/audio_files
ARCHIVE_DIR=/app/data/audio_files

# ===========================================================================
# Refinement (Gemini)
# ===========================================================================
# Leave empty to skip refinement (refinement_score = 0 → MANUAL_REVIEW).
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# ===========================================================================
# Classification + Sentiment (vLLM)
# ===========================================================================
# Dev (vLLM on the WSL host): host.docker.internal is resolved via the
# extra_hosts entry in compose.yaml.
# Prod (vLLM on the same VM or another host): point at the real URL.
VLLM_BASE_URL=http://host.docker.internal:8080/v1
VLLM_MODEL_NAME=Qwen/Qwen3-4B
VLLM_API_KEY=none
VLLM_TEMPERATURE=0.1

# ===========================================================================
# Persistence (PostgreSQL)
# ===========================================================================
# The compose `db` service uses these. The app's DATABASE_URL is built from
# them automatically inside compose.yaml — no need to set it here.
# Required: POSTGRES_PASSWORD (compose refuses to start without it).
POSTGRES_USER=cc_pipeline
POSTGRES_PASSWORD=devlocal
POSTGRES_DB=call_center

# ===========================================================================
# Classification taxonomy override (optional)
# ===========================================================================
# Defaults to src/config/classification_schema.json when unset.
# CLASSIFICATION_SCHEMA_PATH=/abs/path/to/custom_schema.json
