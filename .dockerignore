# Keep the build context (and final image) lean. The image contains only
# code + deps; data, models, and the dev venv are bind-mounted at runtime.

# Virtualenvs
cc_agentic_env/
.venv/
venv/

# Python caches
__pycache__/
*.pyc
*.pyo

# Data — bind-mounted at runtime, never in the image
data/

# Models — bind-mounted at runtime, never in the image
models/

# Local state, IDE, VCS, secrets
.git/
.gitignore
.cursor/
.vscode/
.env
.env.*
!.env.example

# Docs and ad-hoc shell helpers
docs/
README.md
*.md
push_manual.sh
push_with_credentials.sh

# Plan / scratch files (when present)
*.log
