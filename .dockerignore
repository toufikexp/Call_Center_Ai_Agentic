# Keep the build context (and image) small. The image contains only code +
# deps; data and models are bind-mounted at runtime.

# Virtualenvs
cc_agentic_env/
.venv/
venv/

# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Data — never in the image (bind-mounted)
data/audio_files/*
data/results/*
data/logs/*
data/segments/
data/chunks/

# Models — never in the image (bind-mounted / pre-staged)
models/

# VCS + IDE + local
.git/
.gitignore
.cursor/
.vscode/
.env
*.log

# Docs and deploy scripts not needed at runtime
docs/
*.md
push_manual.sh
push_with_credentials.sh
