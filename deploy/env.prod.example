# Production environment template.
#
# Copy to deploy/.env.prod on the prod VM and fill in real values:
#   cp deploy/env.prod.example deploy/.env.prod
# Never commit deploy/.env.prod (it is git-ignored).
#
# Paths below are CONTAINER paths. The host directories are bind-mounted in
# compose.yaml (CC_DATA_DIR -> /app/data, CC_MODELS_DIR -> /opt/cc/models).

# ---------------------------------------------------------------------------
# Offline mode (MANDATORY in production)
# ---------------------------------------------------------------------------
# The prod VM has no general internet. These prevent any HF Hub / torch.hub
# network call; the models must already be present under HF_HOME (pre-staged).
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Where the pre-staged Whisper base model lives (HF cache layout). This is the
# container path; the host dir is mounted at /opt/cc/models.
HF_HOME=/opt/cc/models/huggingface

# ---------------------------------------------------------------------------
# Whisper / LoRA
# ---------------------------------------------------------------------------
WHISPER_BASE_MODEL_ID=openai/whisper-large-v3
WHISPER_ADAPTER_PATH=/opt/cc/models/adapters/whisper-large-v3-lora-algerian_v7
# CPU box: keep the batch small (RAM-bound). bitsandbytes is CUDA-only, leave off.
WHISPER_BATCH_SIZE=2
WHISPER_USE_8BIT=0

# ---------------------------------------------------------------------------
# Preprocessing (channel split + VAD)
# ---------------------------------------------------------------------------
PREPROCESSING_ENABLE=1
# Off in prod — 10K calls of debug WAVs would fill the disk.
PREPROCESSING_SAVE_SEGMENTS=0
VAD_THRESHOLD=0.5
VAD_MIN_SEGMENT_SECONDS=1.0
VAD_MAX_SEGMENT_SECONDS=30.0
VAD_PADDING_MS=250
PREPROCESSING_AGENT_CHANNEL=0
PREPROCESSING_CLIENT_CHANNEL=1

# ---------------------------------------------------------------------------
# Batch I/O (container paths under the mounted /app/data)
# ---------------------------------------------------------------------------
INPUT_DIR=/app/data/audio_files
ARCHIVE_DIR=/app/data/audio_files

# ---------------------------------------------------------------------------
# Refinement — Gemini today, local vLLM later
# ---------------------------------------------------------------------------
# If the prod VM cannot reach Gemini, leave GEMINI_API_KEY empty: refinement
# is skipped, refinement_score=0.0, and every call routes to MANUAL_REVIEW.
# When the local refinement LLM is ready, point it like the vLLM services.
GEMINI_API_KEY=
# GEMINI_MODEL_NAME=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Classification + Sentiment (vLLM)
# ---------------------------------------------------------------------------
# Today: wherever vLLM runs. Future GPU env: change the host here only.
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_MODEL_NAME=Qwen/Qwen3-4B
VLLM_API_KEY=none
VLLM_TEMPERATURE=0.1

# ---------------------------------------------------------------------------
# Persistence (PostgreSQL)
# ---------------------------------------------------------------------------
# STORAGE_ENABLE and DATABASE_URL are set by compose.yaml to point at the `db`
# service. These three feed the postgres container; keep them in sync.
POSTGRES_USER=cc_pipeline
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=call_center
