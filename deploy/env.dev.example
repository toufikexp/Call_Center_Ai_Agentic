# Dev (WSL) container runtime config.
#
#   cp deploy/env.dev.example .env.dev      # then fill in GEMINI_API_KEY
#
# .env.dev is git-ignored. Database credentials are NOT here — for dev they
# live directly in compose.dev.yaml (devlocal). This file is only the app's
# runtime configuration.
#
# These are CONTAINER paths. compose.dev.yaml bind-mounts:
#   ./models                 -> /models   (your existing LoRA adapter)
#   ~/.cache/huggingface     -> /hf       (your existing Whisper download)
#   ./data                   -> /app/data (audio in/out, results, archive)

# Dev has internet — let the container fetch anything not already cached.
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0
HF_HOME=/hf

# Whisper + LoRA. Adapter path is inside the container (./models -> /models).
WHISPER_BASE_MODEL_ID=openai/whisper-large-v3
WHISPER_ADAPTER_PATH=/models/whisper_trained_LoRa_adaptator
WHISPER_BATCH_SIZE=2
WHISPER_USE_8BIT=0

# Preprocessing
PREPROCESSING_ENABLE=1
PREPROCESSING_SAVE_SEGMENTS=0
VAD_THRESHOLD=0.5
VAD_MIN_SEGMENT_SECONDS=1.0
VAD_MAX_SEGMENT_SECONDS=30.0
VAD_PADDING_MS=250
PREPROCESSING_AGENT_CHANNEL=0
PREPROCESSING_CLIENT_CHANNEL=1

# Batch I/O (container paths under the mounted /app/data)
INPUT_DIR=/app/data/audio_files
ARCHIVE_DIR=/app/data/audio_files

# Refinement (Gemini). Paste your key; leave empty to skip refinement.
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.0-flash

# Classification + Sentiment (vLLM running on the WSL host).
# host.docker.internal resolves to the host via the extra_hosts entry in
# compose.dev.yaml. Leave as-is if vLLM runs on the host at :8080.
VLLM_BASE_URL=http://host.docker.internal:8080/v1
VLLM_MODEL_NAME=Qwen/Qwen3-4B
VLLM_API_KEY=none
VLLM_TEMPERATURE=0.1
